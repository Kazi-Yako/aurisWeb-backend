{
	"compilerOptions": {
		"target": "es2020",

		"module": "node16",
		"moduleResolution": "node16",

		"rootDir": "./src",
		"outDir": "./build",

		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,

		"typeRoots": ["./node_modules/@types", "./types"],
		"sourceMap": true
	},
	"exclude": ["node_modules"]
}
